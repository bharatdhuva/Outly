# App
PORT=3001
CLIENT_PORT=3000
NODE_ENV=development

# Gemini AI
GEMINI_API_KEY=AIza...

# Gmail OAuth2 (NOT app password — use proper OAuth)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3001/auth/gmail/callback
GMAIL_REFRESH_TOKEN=
GMAIL_USER=your-email@gmail.com

# Google Drive (for resume)
GOOGLE_DRIVE_REFRESH_TOKEN=
RESUME_DRIVE_FILE_ID=

# LinkedIn (v2.3: Posts are MANUAL only — no API auto-posting for safety)
# LinkedIn API credentials are NOT needed for posting in v2.3
# Only needed for job scraping session via Playwright
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# Twitter/X API (auto-post with Telegram approval)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Reddit (auto-post with Telegram approval)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=JobOS/2.3

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
YOUR_WHATSAPP_NUMBER=whatsapp:+91XXXXXXXXXX

# Telegram Bot (v2.3: Main control center)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_APPROVAL_TIMEOUT_HOURS=2
TELEGRAM_BATCH_APPROVALS=true

# News APIs (optional - Hacker News, Dev.to, GitHub don't need keys)
NEWS_API_KEY=

# Redis (Bull queues)
REDIS_URL=redis://localhost:6379

# SQLite
DB_PATH=./data/jobos.db

# Safety Limits
MAX_EMAILS_PER_DAY=20
MAX_APPLIES_PER_SESSION=15
MAIL_DELAY_MIN_SECONDS=180
MAIL_DELAY_MAX_SECONDS=420
APPLY_DELAY_MIN_SECONDS=45
APPLY_DELAY_MAX_SECONDS=90

# Cron schedules (cron syntax — adjust for your timezone)
WEEKLY_POST_CRON=0 9 * * 1
DAILY_SUMMARY_CRON=0 20 * * *
DAILY_TWEET_CRON=0 8 * * 1-5
WEEKLY_THREAD_CRON=0 19 * * 3
WEEKLY_REDDIT_CRON=0 10 * * 5
MORNING_BRIEFING_CRON=0 8 * * *
DAILY_LINKEDIN_DRAFT_CRON=30 7 * * *

# Follow-up settings
FOLLOWUP_ENABLED=true
FOLLOWUP_DELAY_DAYS=5
FOLLOWUP_CHECK_CRON=0 */6 * * *
