{
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.js": {
      "includeFiles": "backend/dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/auth/:path*",
      "destination": "/api"
    },
    {
      "source": "/create-order",
      "destination": "/api"
    },
    {
      "source": "/verify-payment",
      "destination": "/api"
    },
    {
      "source": "/:path((?!api|auth|create-order|verify-payment).*)",
      "destination": "/index.html"
    }
  ]
}
