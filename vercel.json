{
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.js": {
      "includeFiles": "backend/dist/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api?originalPath=/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
