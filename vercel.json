{
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/auth/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/create-order",
      "destination": "/api/index.js"
    },
    {
      "source": "/verify-payment",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api|auth|create-order|verify-payment).*)",
      "destination": "/index.html"
    }
  ]
}
